            </method>
            <method><name>validateFormInput</name>
                <desc>Проверяет, валидны ли данные, введённые в поле ввода</desc>
                <arg><name>input</name>
                    <type>HTMLInputElement</type>
                    <desc>Поле ввода</desc>
                </arg>
                <ret>bool</ret>
            </method>
