                        <type>xs:string</type>
                        <desc>Смещение папки относительно родительского элемента (aka название папки)</desc>
                    </arg>
                    <arg><name>title</name>
                        <type>xs:string</type>
                        <desc>Заголовок индекса</desc>
                    </arg>
                    <arg><name>desc?</name>
                        <type>xs:string</type>
                        <desc>Описание этой папки с документацией (необязательно)</desc>
                    </arg>
                    <arg><name>file*?</name>
                        <type>file</type>
                        <desc>Файл документации (необязательно, мульти-элемент)</desc>
                    </arg>
                    <arg><name>folder*?</name>
                        <type>xs:string</type>
                        <desc>Подпапка с документацией (необязательно, мульти-элемент)</desc>
                    </arg>
                </xmltag>
                <xmltag><name>file</name>
                    <desc>Файл документации</desc>
                    <arg><name>path</name>
                        <type>xs:string</type>
                        <desc>Название файла документации</desc>
                    </arg>
                    <arg><name>title</name>
                        <type>xs:string</type>
                        <desc>Заголовок файла</desc>
                    </arg>
                    <arg><name>desc?</name>
                        <type>xs:string</type>
                        <desc>Описание этого файла (необязательно)</desc>
                    </arg>
                    <arg><name>method*?</name>
                        <type>method</type>
                        <desc>Метод (необязательно, мульти-элемент)</desc>
                    </arg>
                    <arg><name>xmltag*?</name>
                        <type>xmltag</type>
                        <desc>XML-тег (необязательно, мульти-элемент)</desc>
                    </arg>
                    <arg><name>table*?</name>
                        <type>table</type>
                        <desc>Таблица (необязательно, мульти-элемент)</desc>
                    </arg>
                </xmltag>
            </file>
            <file><path>medium</path>
                <title>Средние метки</title>
                <xmltag><name>method</name>
                    <desc>Метод</desc>
                    <arg><name>name</name>
                        <type>xs:string</type>
                        <desc>Название метода</desc>
                    </arg>
                    <arg><name>desc</name>
                        <type>xs:string</type>
                        <desc>Описание метода</desc>
