                <desc>Кодирует строку в Base64. В отличие от встроенного `btoa`, поддерживает кириллицу</desc>
                <arg><name>str</name>
                    <type>String</type>
                    <desc>Строка для кодирования в Base64</desc>
                </arg>
                <ret>String</ret>
            </method>
            <method><name>b64dec</name>
                <desc>Декодирует строку из Base64. В отличие от встроенного `atob`, поддерживает кириллицу</desc>
                <arg><name>b64str</name>
