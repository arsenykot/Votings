<?xml version="1.0" encoding="utf-8"?>
<docs xmlns="." xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation=". doc/DOC.XSD">
    <path>doc</path>
    <title>Корень документации</title>
    <folder><path>api</path>
        <title>Корень документации API</title>
        <file><path>auth</path>
            <title>Эндпоинты, связанные с автозирацией</title>
            <endpoint><path>api/auth/login</path>
                <method>POST</method>
                <desc>Попытаться войти в систему с указанным именем пользователя и паролем</desc>
                <arg><name>username</name>
                    <type>str</type>
                    <desc>Имя пользователя</desc>
                </arg>
                <arg><name>password</name>
                    <type>str</type>
                    <desc>Пароль</desc>
                </arg>
                <resp><code>400</code><data>BADREQUEST</data>
                    <when>Недостаточно аргументов</when>
                </resp>
                <resp><code>403</code><data>BADCREDENTIALS</data>
                    <when>Переданные имя пользователя и / или пароль неверны</when>
                </resp>
                <resp><code>200</code><data>OK</data>
                    <when>Авторизация прошла успешно</when>
                </resp>
            </endpoint>
            <endpoint><path>api/auth/logout</path>
                <method>GET / POST</method>
                <desc>Выйти из аккаунта пользователя и перейти на главную страницу</desc>
            </endpoint>
        </file>
        <file><path>registration</path>
            <title>Эндпоинты, связанные с регистрацией</title>
            <endpoint><path>api/registration/check_name</path>
                <method>GET</method>
                <desc>Проверяет, занято ли указанное имя</desc>
                <arg><name>username</name>
                    <type>str</type>
                    <desc>Имя пользователя</desc>
                </arg>
                <resp><code>400</code><data>BADREQUEST</data>
                    <when>Не указано имя пользователя</when>
                </resp>
                <resp><code>400</code><data>REGEX</data>
                    <when>Имя пользователя содержит недопустимые символы</when>
                </resp>
                <resp><code>200</code><data>OK</data>
                    <when>Указанное имя свободно</when>
                </resp>
                <resp><code>200</code><data>TAKEN</data>
                    <when>Указанное имя занято</when>
                </resp>
            </endpoint>
            <endpoint><path>api/registration/register</path>
                <method>POST</method>
                <desc>Создаёт аккаунт с указанным именем пользователя и паролем, затем авторизуется в него</desc>
                <arg><name>username</name>
                    <type>str[4..24]</type>
                    <desc>Имя пользователя</desc>
                </arg>
                <arg><name>password</name>
                    <type>str[8..]</type>
                    <desc>Пароль</desc>
                </arg>
                <resp><code>400</code><data>BADREQUEST</data>
                    <when>Недостаточно аргументов или формат аргументов некорректный</when>
                </resp>
                <resp><code>400</code><data>REGEX</data>
                    <when>Имя пользователя содержит недопустимые символы</when>
                </resp>
                <resp><code>400</code><data>USERNAMETAKEN</data>
                    <when>Имя пользователя занято</when>
                </resp>
                <resp><code>200</code><data>OK</data>
                    <when>Аккаунт создан, авторизация выполнена</when>
                </resp>
            </endpoint>
        </file>
        <file><path>votings</path>
            <title>Эндпоинты, связанные с голосованиями</title>
            <endpoint><path>api/votings/new</path>
                <method>POST</method>
                <desc>Создаёт голосование</desc>
                <arg><name>name</name>
                    <type>String[1..48]</type>
                    <desc>Название голосования</desc>
                </arg>
                <arg><name>description</name>
                    <type>String[1..512]?</type>
                    <desc>Описание голосования</desc>
                </arg>
                <arg><name>options</name>
                    <type>String</type>
                    <desc>Base64-закодированная строка, содержащая все опции в формате JSON.</desc>
                </arg>
                <arg><name>close</name>
                    <type>"auto" | "manual"</type>
                    <desc>Способ закрытия голосования</desc>
                </arg>
                <arg><name>multichoice</name>
                    <type>"on"?</type>
                    <desc>Возможность выбора нескольких вариантов ответа. Если не указано - выключено, иначе - включено</desc>
                </arg>
                <arg><name>date</name>
                    <type>String?</type>
                    <desc>Дата автоматического закрытия. Только при `close = auto`</desc>
                </arg>
                <arg><name>time</name>
                    <type>String?</type>
                    <desc>Время автоматического закрытия. Только при `close = auto`</desc>
                </arg>
                <resp><code>400</code><data>BADREQUEST</data>
                    <when>Передано недостаточно аргументов или аргументы имеют неверный формат</when>
                </resp>
                <resp><code>400</code><data>BADDATE</data>
                    <when>Дата и/или время имеют неверный формат</when>
                </resp>
                <resp><code>400</code><data>DATEINPAST</data>
                    <when>Дата и время находятся в прошлом</when>
                </resp>
                <resp><code>400</code><data>TOOFEWOPTIONS</data>
                    <when>Слишком мало вариантов ответа</when>
                </resp>
                <resp><code>400</code><data>TOOMANYOPTIONS</data>
                    <when>Слишком много вариантов ответа</when>
                </resp>
                <resp><code>401</code><data>UNAUTHORIZED</data>
                    <when>Пользователь не авторизован</when>
                </resp>
                <resp><code>200</code><data>OK</data>
                    <when>Голосование успешно создано</when>
                </resp>
            </endpoint>
        </file>
    </folder>
    <folder><path>js</path>
        <title>Корень документации JavaScript</title>
        <desc>Документация для функционала, реализованого в `/main/static/util.js` и доступного при использовании любого из шаблонов в `abc/`</desc>
        <file><path>ajax</path>
            <title>Методы AJAX</title>
            <desc>Предоставляет методы для работы с AJAX. Функционал реализован в `/main/static/util.js` в регионе `ajax`</desc>
            <method><name>ajaxQuery</name>
                <desc>Осуществляет асинхронный запрос на сервер</desc>
                <arg><name>endpoint</name>
                    <type>String</type>
                    <desc>Конечная точка API, на которую будет направлен запрос</desc>
                </arg>
                <arg><name>method</name>
                    <type>"GET"|"POST"</type>
                    <desc>Метод отправляемого запроса</desc>
                </arg>
                <arg><name>ready_callback</name>
                    <type>Function[AJAXResponse]</type>
                    <desc>Метод, который будет вызван по готовности запроса. Должен принимать фиктивный объект AJAXResponse, описанный в примечании</desc>
                </arg>
                <arg><name>data</name>
                    <type>Object</type>
                    <desc>Тело запроса в виде объекта</desc>
                </arg>
                <arg><name>error_passthrough</name>
                    <type>Boolean</type>
                    <desc>Указывает, попадёт ли ошибка в метод по готовности (по умолчанию - нет)</desc>
                </arg>
                <arg><name>httpheaders</name>
                    <type>Array[Array[String]]</type>
                    <desc>Массив пар типа `["ключ", "значение"]`, задающий HTTP-аргументы запроса. По умолчанию пуст</desc>
                </arg>
                <ret>null</ret>
            </method>
            <method><name>ajaxGet</name>
                <desc>Алиас для `ajaxQuery`, где `method="GET"`</desc>
                <argsor>endpoint, ready_callback, data, error_passthrough, httpheaders</argsor>
                <ret>null</ret>
            </method>
            <method><name>ajaxPost</name>
                <desc>Алиас для `ajaxQuery`, где `method="POST"`</desc>
                <argsor>endpoint, ready_callback, data, error_passthrough, httpheaders</argsor>
                <ret>null</ret>
            </method>
            <table><name>Примечание: Формат фиктивного объекта AJAXResponse</name>
                <header>Поле;Тип;Описание</header>
                <row>`status`;`Number|"error"`;HTTP-статус ответа ИЛИ "error" в случае ошибки, когда `error_passthrough` включено.</row>
                <row>`content`;`String?`;Контент ответа на запрос (не существует при `status == "error"`)</row>
                <row>`error`;`Object?`;Текст ошибки (не существует при `status != "error"`)</row>
            </table>
        </file>
        <file><path>htmlutils</path>
            <title>Утилиты для HTML</title>
            <desc>Предоставляет методы-утилиты для работы с HTML. Функционал реализован в `/main/static/util.js` в регионе `htmlutils`</desc>
            <method><name>setSpinner</name>
                <desc>Заменяет `innerHTML` элемента на спиннер с указанным текстом.</desc>
                <arg><name>element</name>
                    <type>HTMLElement</type>
                    <desc>Целевой элемент</desc>
                </arg>
                <arg><name>text</name>
                    <type>String</type>
                    <desc>Текст возле спиннера</desc>
                </arg>
                <arg><name>size</name>
                    <type>"sm"|"lg"?</type>
                    <desc>Размер спиннера. По умолчанию `sm`. См. [документацию для спиннеров](https://getbootstrap.com/docs/5.3/components/spinners/)</desc>
                </arg>
                <arg><name>type</name>
                    <type>"border"|"grow"?</type>
                    <desc>Тип анимации спиннера. По умолчанию `border`. См. [документацию для спиннеров](https://getbootstrap.com/docs/5.3/components/spinners/)</desc>
                </arg>
                <ret>null</ret>
            </method>
            <method><name>spawnToast</name>
                <desc>Создаёт уведомление-тост с указанными параметрами</desc>
                <arg><name>color</name>
                    <type>String</type>
                    <desc>Цвет уведомления-тоста. См. [Список цветов](https://getbootstrap.com/docs/5.3/customize/color/#theme-colors)</desc>
                </arg>
                <arg><name>icon</name>
                    <type>String</type>
                    <desc>Название иконки [отсюда](https://icons.getbootstrap.com/)</desc>
                </arg>
                <arg><name>content</name>
                    <type>String</type>
                    <desc>HTML-содержимое уведомления-тоста</desc>
                </arg>
                <arg><name>closeButton</name>
                    <type>Boolean</type>
                    <desc>Указывает, будет ли видна кнопка закрытия тоста. По умолчанию `false`</desc>
                </arg>
                <arg><name>container</name>
                    <type>HTMLElement</type>
                    <desc>HTML-элемент, в который требуется поместить тост. По умолчанию элемент с ID `toast-container`</desc>
                </arg>
                <ret>null</ret>
            </method>
            <method><name>errorToast</name>
                <desc>Создаёт toast с ошибкой, если код ошибки отличается от предыдущего созданного</desc>
                <arg><name>error</name>
                    <type>String</type>
                    <desc>Внутреннее название ошибки. Используется для предотвращения спама ошибками</desc>
                </arg>
                <arg><name>text</name>
                    <type>String</type>
                    <desc>Текст ошибки</desc>
                </arg>
                <ret>null</ret>
            </method>
            <method><name>clearError</name>
                <desc>Очищает последнюю созданную ошибку через errorToast</desc>
                <ret>null</ret>
            </method>
        </file>
        <file><path>formutils</path>
            <title>Утилиты для работы с формами</title>
            <desc>Предоставляет методы-утилиты для работы с формами. Функционал реализован в `/main/static/util.js` в регионе `formutils`</desc>
            <method><name>validateForm</name>
                <desc>Проверяет, валидны ли данные, введённые в форму</desc>
